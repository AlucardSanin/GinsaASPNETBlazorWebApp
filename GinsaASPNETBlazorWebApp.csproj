<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>GinsaASPNETBlazorWebApp</RootNamespace>
    <AssemblyName>GinsaASPNETBlazorWebApp</AssemblyName>
  </PropertyGroup>

  <!-- Scratch exports used during design; keep them out of publish packages. -->
  <ItemGroup>
    <Content Remove="wwwroot\images\_tmp\**" />
    <None Include="wwwroot\images\_tmp\**" />
  </ItemGroup>

</Project>
