<section class="numeros" id="numeros">
    <div class="container">
        <h2 class="section-title numeros__title reveal">Números que <span class="fun">hablan</span> por sí solos</h2>

        <div class="numeros__stage reveal" tabindex="0" aria-label="Galería de resultados. Pasa el cursor para expandir.">
            <div class="numeros__figs" aria-hidden="true">
                <img class="numeros__fig numeros__fig--bird" src="images/numeros-bird.png?v=5" alt="" />
                <img class="numeros__fig numeros__fig--spark" src="images/numeros-figure2.png?v=5" alt="" />
                <img class="numeros__fig numeros__fig--wave" src="images/numeros-figure3.png?v=5" alt="" />
                <div class="numeros__fig numeros__fig--smiley" aria-hidden="true">
                    <span class="numeros__smiley-face">;)</span>
                </div>
                <img class="numeros__fig numeros__fig--semi" src="images/numeros-semicircle.png?v=5" alt="" />
                <img class="numeros__fig numeros__fig--blob" src="images/numeros-figure.png?v=5" alt="" />
            </div>

            <div class="numeros__gallery">
                <img class="numeros__card" src="images/phone-profile-1.png" alt="Perfil de Instagram" />
                <img class="numeros__card" src="images/stats-reels.png" alt="Estadísticas de reels" />
                <img class="numeros__card" src="images/phone-profile-2.png" alt="Perfil de Instagram" />
                <img class="numeros__card" src="images/stats-anuncios.png" alt="Estadísticas de anuncios" />
                <img class="numeros__card" src="images/stats-resumen.png" alt="Resumen de estadísticas" />
                <img class="numeros__card" src="images/stats-seguidores.png" alt="Seguidores" />
            </div>
        </div>
    </div>
</section>
