<header class="hero">

    <img class="decor decor--curl-l" src="@Assets["images/curl1.svg"]" alt="" aria-hidden="true" />

    <img class="decor decor--curl-r" src="@Assets["images/curl2.svg"]" alt="" aria-hidden="true" />

    <img class="decor decor--hexagon" src="@Assets["images/hexagon.svg"]" alt="" aria-hidden="true" />

    <img class="decor decor--periwinkle-a" src="@Assets["images/quote-curl.svg"]" alt="" aria-hidden="true" />

    <img class="decor decor--periwinkle-b" src="@Assets["images/quote-curl.svg"]" alt="" aria-hidden="true" />

    <img class="decor decor--quote" src="@Assets["images/quote-right.svg"]" alt="" aria-hidden="true" />

    <div class="container hero__inner">

        <div class="hero__brand">

            <img class="hero__intro" src="@Assets["images/hero-intro.webp"]" alt="We are Arrieta Agency" />

            <img class="hero__smile" src="@Assets["images/smile.svg"]" alt="Arrieta" aria-hidden="true" />

        </div>

        <p class="hero__headline">

            <span class="top">Creatividad + estrategia personalizada =</span><br />

            <span class="bottom">Los resultados que buscas</span>

        </p>



        <div class="hero__cta">

            <p class="lead">Trabajemos juntos</p>

            <div class="country-row">

                <button class="country-btn on-dark">

                    <img class="flag" src="@Assets["images/flag-co.svg"]" alt="" />

                    <span class="label">Colombia</span>

                    <img class="arrow" src="@Assets["images/icon-arrow.svg"]" alt="" />

                </button>

                <button class="country-btn on-dark">

                    <img class="flag" src="@Assets["images/flag-ve.svg"]" alt="" />

                    <span class="label">Venezuela</span>

                    <img class="arrow" src="@Assets["images/icon-arrow.svg"]" alt="" />

                </button>

            </div>

        </div>

    </div>

</header>

